# BACKEND (.env in /backend)
GROQ_API_KEY=your_groq_api_key_here
MONGO_URI=your_mongodb_atlas_uri_here
FRONTEND_URL=https://your-production-frontend-url.com
API_URL=https://your-production-backend-url.com
PORT=8000
ENVIRONMENT=production
GOOGLE_CREDENTIALS_PATH=/etc/secrets/credentials.json # Set this to where your credentials file lives in production

# FRONTEND (.env in /frontend)
NEXT_PUBLIC_API_URL=https://your-production-backend-url.com
